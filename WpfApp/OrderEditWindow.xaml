<Window x:Class="WpfApp.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ"
        Height="420"
        Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Times New Roman">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК -->
        <TextBlock Grid.Row="0"
                   Text="Информация о заказе"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Foreground="#333"/>

        <!-- ОСНОВНАЯ ФОРМА -->
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Артикул -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Артикул:" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       x:Name="ArticleTextBlock"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- Статус -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" Margin="0,10,0,0" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      x:Name="StatusComboBox"
                      Height="28"
                      Margin="0,10,0,0">
                <ComboBoxItem Content="Новый"/>
                <ComboBoxItem Content="Завершен"/>
            </ComboBox>

            <!-- Пункт выдачи -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Пункт выдачи:" Margin="0,10,0,0" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1"
                      x:Name="PickupPointComboBox"
                      Height="28"
                      Margin="0,10,0,0"
                      DisplayMemberPath="Address"/>

            <!-- Дата заказа -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата заказа:" Margin="0,10,0,0" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="3" Grid.Column="1"
                         x:Name="OrderDatePicker"
                         Height="28"
                         Margin="0,10,0,0"/>

            <!-- Дата выдачи -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата выдачи:" Margin="0,10,0,0" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="4" Grid.Column="1"
                         x:Name="DeliveryDatePicker"
                         Height="28"
                         Margin="0,10,0,0"/>

        </Grid>

        <!-- КНОПКИ -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Отмена"
                    Width="110"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="#E0E0E0"
                    Click="CancelButton_Click"/>

            <Button Content="Сохранить"
                    Width="110"
                    Height="32"
                    Background="#00FA9A"
                    Click="SaveButton_Click"/>
        </StackPanel>

    </Grid>
</Window>