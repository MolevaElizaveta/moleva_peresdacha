<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp"
        Title="Магазин обуви" Height="700" Width="1100"
        WindowState="Maximized"
        Background="#FFFFFF"
        FontFamily="Times New Roman"
        Closing="Window_Closing">

    <Window.Resources>
        <local:ProductImageConverter x:Key="ProductImageConverter"/>
        <local:RelatedNameConverter x:Key="RelatedNameConverter"/>
        <local:ProductRowBackgroundConverter x:Key="ProductRowBackgroundConverter"/>
        <BitmapImage x:Key="LogoIcon" UriSource="/images/Icon.png"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#7FFF00" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип компании -->
                <Image Grid.Column="0" Source="images/Icon.png" Width="40" Height="40"
                       VerticalAlignment="Center" Margin="0,0,10,0" Stretch="Uniform"/>

                <!-- Заголовок -->
                <TextBlock Grid.Column="1" x:Name="TitleTextBlock" Text="Магазин обуви" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#333333"
                           FontFamily="Times New Roman" Margin="0,0,20,0"/>

                <!-- Имя пользователя -->
                <TextBlock Grid.Column="2" x:Name="UserTextBlock" Foreground="#333333" FontSize="16"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontFamily="Times New Roman"/>

                <!-- Кнопки справа -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="DictionaryButton" Content="Справочники" Width="120" Height="30"
                            Margin="0,0,10,0" Background="#87CEEB" Foreground="#333333"
                            BorderThickness="1" Cursor="Hand" Click="DictionaryButton_Click"
                            FontFamily="Times New Roman"/>
                    <Button x:Name="OrdersButton" Content="Заказы" Width="100" Height="30"
                            Background="#00FA9A" Foreground="#333333"
                            BorderThickness="1" Cursor="Hand" Click="OrdersButton_Click"
                            FontFamily="Times New Roman"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Margin="10" FontFamily="Times New Roman">

            <!-- Вкладка Товары -->
            <TabItem Header="Товары" FontFamily="Times New Roman">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель управления -->
                    <Border Grid.Row="0" Background="#F8F8F8" Padding="10" Visibility="Collapsed" x:Name="ControlPanel">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0,5,0" FontFamily="Times New Roman"/>
                            <TextBox x:Name="SearchTextBox" Width="200" Height="28" Margin="0,0,10,0"
                                     TextChanged="SearchTextBox_TextChanged" FontFamily="Times New Roman"/>

                            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="5,0,5,0" FontFamily="Times New Roman"/>
                            <ComboBox x:Name="SortComboBox" Width="160" Height="28" Margin="0,0,10,0"
                                      SelectionChanged="SortComboBox_SelectionChanged" FontFamily="Times New Roman">
                                <ComboBoxItem Content="Без сортировки"/>
                                <ComboBoxItem Content="Остаток (возр.)"/>
                                <ComboBoxItem Content="Остаток (убыв.)"/>
                            </ComboBox>

                            <TextBlock Text="Поставщик:" VerticalAlignment="Center" Margin="5,0,5,0" FontFamily="Times New Roman"/>
                            <ComboBox x:Name="SupplierFilterComboBox" Width="160" Height="28" Margin="0,0,10,0"
                                      SelectionChanged="SupplierFilterComboBox_SelectionChanged" DisplayMemberPath="Name" FontFamily="Times New Roman"/>

                            <Button x:Name="AddProductButton" Content="Добавить товар" Width="140" Height="28"
                                    Margin="10,0,0,0" Background="#00FA9A" Foreground="#333333"
                                    BorderThickness="1" Cursor="Hand" Click="AddProductButton_Click"
                                    FontFamily="Times New Roman" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Список товаров -->
                    <Border Grid.Row="1" Margin="0,5,0,5" BorderBrush="#E0E0E0" BorderThickness="1">
                        <ListBox x:Name="ProductsListBox" BorderThickness="0"
                                 Background="White"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionMode="Single"
                                 MouseDoubleClick="ProductsListBox_MouseDoubleClick">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>

                                    <!-- ВАЖНО: фон прямо тут -->
                                    <Border Margin="5"
            Padding="10"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            HorizontalAlignment="Stretch">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding StockQuantity}" Value="0">
                                                        <Setter Property="Background" Value="LightBlue"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding DiscountPercent}" Value="16">
                                                        <Setter Property="Background" Value="#2E8B57"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding DiscountPercent}" Value="17">
                                                        <Setter Property="Background" Value="#2E8B57"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding DiscountPercent}" Value="18">
                                                        <Setter Property="Background" Value="#2E8B57"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding DiscountPercent}" Value="19">
                                                        <Setter Property="Background" Value="#2E8B57"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding DiscountPercent}" Value="20">
                                                        <Setter Property="Background" Value="#2E8B57"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid HorizontalAlignment="Stretch">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="5*"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 🖼 Фото -->
                                            <Image Grid.Column="0"
                   Source="{Binding PhotoPath, Converter={StaticResource ProductImageConverter}}"
                   Width="120"
                   Height="120"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                                            <!-- 📦 Инфо -->
                                            <StackPanel Grid.Column="1"
                        Margin="10,0,10,0"
                        VerticalAlignment="Center">

                                                <TextBlock Text="{Binding Name}"
                           FontSize="16"
                           FontWeight="Bold"/>

                                                <TextBlock Text="{Binding CategoryName, StringFormat=Категория: {0}}"/>
                                                <TextBlock Text="{Binding ManufacturerName, StringFormat=Производитель: {0}}"/>
                                                <TextBlock Text="{Binding SupplierName, StringFormat=Поставщик: {0}}"/>

                                                <TextBlock Text="{Binding Unit, StringFormat=Ед.: {0}}"/>
                                                <TextBlock Text="{Binding StockQuantity, StringFormat=Остаток: {0}}"/>

                                                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Foreground="#555"/>
                                            </StackPanel>

                                            <!-- 💰 Скидка -->
                                            <Border Grid.Column="2"
                    Width="110"
                    Height="110"
                    CornerRadius="6"
                    Background="#F5F5F5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                                                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                                                    <TextBlock Text="{Binding DiscountPercent, StringFormat={}{0}%}"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                                                    <TextBlock Text="{Binding PriceWithDiscount, StringFormat={}{0:C2}}"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                        </Grid>
                                    </Border>

                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Кнопки управления -->
                    <Border Grid.Row="2" Background="#F8F8F8" Padding="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="EditProductButton" Content="Редактировать" Width="140" Height="32"
                                    Margin="0,0,5,0" Background="#00FA9A" Foreground="#333333"
                                    BorderThickness="1" Cursor="Hand" Click="EditProductButton_Click"
                                    FontFamily="Times New Roman" Visibility="Collapsed"/>
                            <Button x:Name="DeleteProductButton" Content="Удалить товар" Width="130" Height="32"
                                    Background="#FF6347" Foreground="White" BorderThickness="1"
                                    Cursor="Hand" Click="DeleteProductButton_Click"
                                    FontFamily="Times New Roman" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка Пункты выдачи -->
            <TabItem Header="Пункты выдачи" FontFamily="Times New Roman">
                <Grid Margin="5">
                    <DataGrid x:Name="PickupPointsDataGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" AlternatingRowBackground="#F5F5F5"
                              GridLinesVisibility="Horizontal" FontFamily="Times New Roman" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                            <DataGridTextColumn Header="Район" Binding="{Binding District}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Статусная строка -->
        <Border Grid.Row="2" Background="#F8F8F8" Padding="10">
            <TextBlock x:Name="StatusTextBlock" Text="Готово" Foreground="#666666"
                       FontFamily="Times New Roman"/>
        </Border>
    </Grid>
</Window>